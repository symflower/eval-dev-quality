	package light

	import (
		"reflect"
		"testing"
	)

	func TestMagicSquareOdd(t *testing.T) {
		type args struct {
			base int
		}
		tests := []struct {
			name    string
			args    args
			want    [][]int
			wantErr error
		}{
			{
				name:    "Base 3",
				args:    args{base: 3},
				want:    [][]int{{8, 1, 6}, {3, 5, 7}, {4, 9, 2}},
				wantErr: nil,
			},
			{
				name:    "Base 5",
				args:    args{base: 5},
				want:    [][]int{{17, 2, 15, 7, 3}, {24, 10, 13, 5, 11}, {18, 6, 12, 16, 4}, {25, 14, 9, 19, 8}, {1, 11, 17, 22, 20}},
				wantErr: nil,
			},
			{
				name:    "Base 4 (Even)",
				args:    args{base: 4},
				wantErr: errors.New("base must be odd and > 2"),
			},
			{
				name:    "Base 1",
				args:    args{base: 1},
				wantErr: errors.New("base must be odd and > 2"),
			},
		}
		for _, tt := range tests {
			t.Run(tt.name, func(t *testing.T) {
				got, err := magicSquareOdd(tt.args.base)
				if err != nil {
					if !reflect.DeepEqual(err, tt.wantErr) {
						t.Errorf("magicSquareOdd() error = %v, wantErr %v", err, tt.wantErr)
					}
					return
				}
				if !reflect.DeepEqual(got, tt.want) {
					t.Errorf("magicSquareOdd() = %v, want %v", got, tt.want)
				}
			})
		}
	}
