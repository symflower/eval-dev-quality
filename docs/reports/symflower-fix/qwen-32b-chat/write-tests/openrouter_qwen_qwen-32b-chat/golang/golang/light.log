			output  string
			err     error
		ighborhood error
		}{
			{"Empty input", "", "", nil, nil},
			{"Single digit", "1", "1", nil, nil},
			{"Multiple digits", "1234567890", "1234567890", nil, nil},
			{"Spaces removed", "1 2 3 4 5 6 7 8 9 0", "1234567890", nil, nil},
			{"Dots removed", "1.2.3.4.5.6.7.8.9.0", "1234567890", nil, nil},
			{"Parentheses removed", "1(23)45-67890", "1234567890", nil, nil},
			{"Hyphens removed", "123-45-67890+", "-1234567890", errors.New("punctuations not permitted"), nil},
			{"Plus sign removed", "+123-45-67890", "1234567890", nil, nil},
			{"Invalid punctuation", "123!@#456", "", errors.New("punctuations not permitted"), nil},
			{"Invalid letter", "123abc456", "", errors.New("letters not permitted"), nil},
			{"Mixed case digits", "12B3C4D5E6", "", errors.New("letters not permitted"), nil},
		}
		for _, testCase := range testCases {
			t.Run(testCase.name, func(t *testing.T) {
