	)

	func TestLargestProperDivisor(t *testing.T) {
		rand.Seed(time.Now().UnixNano())

		// Positive integers
		for i := 1; i <= 100; i++ {
			aNumber := rand.Intn(1000) + 1
			expected := findLargestProperDivisorManually(aNumber)
		 divisor, err := largestProperDivisor(aNumber)
			if err != nil {
				t.Errorf("Error computing largest proper divisor for %d: %v", aNumber, err)
			}
			if divisor != expected {
				t.Errorf("Expected largest proper divisor for %d is %d, got %d", aNumber, expected, divisor)
			}
		}

		// Edge cases
		for _, tc := range []struct {
			aNumber int
			err     string
		}{
			{-1, "Argument must be >= 1: -1"},
			{0, "Argument must be >= 1: 0"},
		} {
			_, err := largestProperDivisor(tc.aNumber)
			if err == nil || err.Error() != tc.err {
				t.Errorf("Expected error '%s' for %d, got '%v'", tc.err, tc.aNumber, err)
			}
		}
	}

	func findLargestProperDivisorManually(n int) int {
		for i := 2; i <= n/2; i++ {
			if n%i == 0 {
				return n / i
			}
		}
		return 1
	}
