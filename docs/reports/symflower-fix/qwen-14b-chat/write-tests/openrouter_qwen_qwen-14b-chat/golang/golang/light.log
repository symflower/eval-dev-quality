			if err != nil && err.Error() != tc.errCode {
				t.Errorf("Expected error: %s, got: %s", tc.errCode, err.Error())
			} else if err == nil && err.Error() != tc.errCode {
				assert.Equal(t, tc.expected, result, fmt.Sprintf("For aNumber %d, expected %d, got %d", tc.aNumber, tc.expected, result))
			} else {
				continue
			}
		}

		// Test case without a divisor
		errTest := largestProperDivisor(99997)
		assert.Error(t, errTest, "Expected error for prime number")
		assert.Equal(t, "no divisor found", errTest.Error(), "Expected error message")

		// Test tiny prime number
		errTest = largestProperDivisor(2)
		assert.Error(t, errTest, "Expected error for prime number")
		assert.Equal(t, "no divisor found", errTest.Error(), "Expected error message for prime number")
	}
