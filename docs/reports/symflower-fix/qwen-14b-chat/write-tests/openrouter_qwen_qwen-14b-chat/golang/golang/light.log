			{29, 2, 2000, true},
			{31, 12, 2021, true},
			{30, 9, 2022, true},
		}

		for _, test := range validDates {
			if validDate(test.day, test.month, test.year) != test.result {
				t.Errorf("validDate(%d, %d, %d) returned %t, expected %t", test.day, test.month, test.year, validDate(test.day, test.month, test.year), test.result)
			}
		}

		// Test cases for invalid dates
		invalidDates := []struct {
			day   int
			month int
			year  int
			result bool
		}{
			{-1, 1, 1, false},
			{32, 1, 2023, false},
			{31, 2, 1900, false}, // February 1900 should not be leap year
			{29, 2, 1901, false}, // February 1901 should not be leap year
			{0, 1, 1, false},
		}

		for _, test := range invalidDates {
			if validDate(test.day, test.month, test.year) != test.result {
				t.Errorf("validDate(%d, %d, %d) returned %t, expected %t", test.day, test.month, test.year, validDate(test.day, test.month, test.year), test.result)
			}
		}

		// Test a leap year and non-leap year
		if validDate(29, 2, 2024) != true {
			t.Error("validDate(29, 2, 2024) returned false, expected true due to leap year")
		}
		if validDate(29, 2, 1900) != false {
			t.Error("validDate(29, 2, 1900) returned true, expected false since 1900 is not a leap year")
		}
	}

	func BenchmarkValidDate(b *testing.B) {
		// Benchmarking the function is optional but can be useful for performance testing
		for i := 0; i < b.N; i++ {
			_ = validDate(1, 1, 2023)
			_ = validDate(29, 2, 2000)
			_ = validDate(31, 12, 1980)
		}
	}
	```
	This test file includes test cases for valid and invalid dates, ensuring that all possible conditions in the `validDate` function are covered. The `BenchmarkValidDate` function is also included for benchmarking purposes, although it is not strictly necessary for code coverage.
