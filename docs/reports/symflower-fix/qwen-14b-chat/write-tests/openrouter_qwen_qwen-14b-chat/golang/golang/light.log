	func TestExtractDigits(t *testing.T) {
		// Test cases with valid phone numbers
		fixtures := []struct {
			dirtyNumber string
			cleanNumber string
			err         error
		}{
			{"123-456-7890", "1234567890", nil},
			{"123.456.7890", "1234567890", nil},
			{"(123) 456-7890", "1234567890", nil},
			{"+1 123 456 7890", "11234567890", nil},
			{"+123-456-7890", "1234567890", nil},
		}

		for _, fixture := range fixtures {
			cleanNumber, err := extractDigits(fixture.dirtyNumber)
			if err != nil {
				if fixture.err != nil && fixture.err.Error() == err.Error() {
					continue
				}
				t.Errorf("Expected error '%v', got '%v' for dirty number: %s", fixture.err, err, fixture.dirtyNumber)
			} else {
				if fixture.err != nil {
					t.Errorf("Expected error, but got clean number: %s -> %s", fixture.dirtyNumber, cleanNumber)
				} else if cleanNumber != fixture.cleanNumber {
					t.Errorf("Mismatching clean number: expected %s, got %s for dirty number: %s", fixture.cleanNumber, cleanNumber, fixture.dirtyNumber)
				}
			}
		}

		// Test cases with invalid phone numbers
		badFixtures := []struct {
			dirtyNumber string
			err         error
		}{
			{"123-456-7890@", "", errors.New("punctuations not permitted")},
			{"123-456-7890!", "", errors.New("punctuations not permitted")},
			{"123-456-7890!", "", errors.New("punctuations not permitted")},
			{"123-456-7890-123", "", errors.New("punctuation not permitted")},
			{"1@123-456-7890", "", errors.New("letters not permitted")},
			{"12!", "", errors.New("letters not permitted")},
			{"1a123-456-7890", "", errors.New("letters not permitted")},
		}

		for _, fixture := range badFixtures {
			_, err := extractDigits(fixture.dirtyNumber)
			if err == nil {
				t.Errorf("Expected error '%v', got none for dirty number: %s", fixture.err, fixture.dirtyNumber)
			} else if fixture.err.Error() != err.Error() {
				t.Errorf("Expected error '%v', got '%v' for dirty number: %s", fixture.err, err, fixture.dirtyNumber)
			}
		}
	}
