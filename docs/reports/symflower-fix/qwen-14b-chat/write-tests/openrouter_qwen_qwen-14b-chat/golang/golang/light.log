	func TestLargestProperDivisor(t *testing.T) {
		// Test cases with valid inputs
		validCases := []struct {
			aNumber int
			expected int
			errCode  string
		}{
			{1, 1, "Argument must be >= 1: 1"},
			{2, 1, "", // 1 is the largest proper divisor for even numbers
			{3, 1, "", // 1 is the largest proper divisor
			{4, 2, "", // 2 is the largest proper divisor (even case tested separately)
			{9, 3, "", // 3 is the largest proper divisor
			{10, 5, "", // 5 is the largest proper divisor
			{97, 3, "", // 3 is the largest proper divisor
